# Clear stale dev server types (generated by Turbopack, go stale when dev server stops)
rm -f .next/dev/types/*.ts .next/dev/types/*.d.ts 2>/dev/null

# Lockfile consistency check — catches the lint-staged stash/restore bug
# where bun.lock gets dropped from the commit after `bun add`. CI uses
# --frozen-lockfile so a stale lockfile fails every job.
if ! bun install --frozen-lockfile 2>/dev/null; then
  echo "" >&2
  echo "ERROR: bun.lock is out of sync with package.json." >&2
  echo "  → Run: bun install && git add bun.lock && git commit --amend" >&2
  echo "" >&2
  exit 1
fi

bun run typecheck
bun run test
bun run build
