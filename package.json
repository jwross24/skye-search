{
  "name": "skye-search",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:changed": "vitest run --changed",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "bun run typecheck && bun run lint && vitest run --coverage && bun run test:integration && playwright test",
    "eval:queries": "bun run scripts/eval-queries.ts",
    "eval:queries:cached": "bun run scripts/eval-queries.ts --judge-only",
    "verify": "bun run build && bun run lint && bun run test && bash scripts/check-integration-mocks.sh && if which ntm >/dev/null 2>&1; then ntm scan --staged --fail-on-warning; else echo 'ntm not installed, skipping scan'; fi",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --no-warn-ignored --max-warnings 0",
      "vitest related --run"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@react-email/components": "^1.0.10",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "archiver": "^7.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exa-js": "^2.10.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.0.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "resend": "^6.9.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-plugin-testing-library": "^7.16.1",
    "eslint-plugin-vitest": "^0.5.4",
    "happy-dom": "^20.8.7",
    "husky": "^9.1.7",
    "jszip": "^3.10.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.14",
    "supabase": "^2.83.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.1"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "supabase",
    "unrs-resolver"
  ]
}
