# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
supabase/functions/.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env.local

# bv (beads viewer) local config and caches
.bv/

# Agent skill cache (generated, mirrors .claude/skills/)
.agents/

# Track project-specific Claude config (overrides global .claude/* ignore)
!.claude/
!.claude/**
.claude/.*-stamp*
.claude/.command-log-*
.claude/.review-disposition-*
.claude/.cross-review-results.json
.claude/.bead-close-count*
.claude/settings.local.json
supabase/.temp/
