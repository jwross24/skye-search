# ─── Local Supabase (default: run `supabase start` first) ──────────────────
# These values come from `supabase status` after starting local instance.
# Production values go in Vercel env vars, NOT here.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# ─── AI ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Job Discovery ─────────────────────────────────────────────────────────
EXA_API_KEY=your_exa_api_key
USAJOBS_API_KEY=your_usajobs_api_key
USAJOBS_USER_AGENT=your_registered_email@example.com

# ─── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=SkyeSearch <noreply@yourdomain.com>
RESEND_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────
# Generate once: bunx web-push generate-vapid-keys
# NEXT_PUBLIC_ prefix required — browser needs the public key to subscribe
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
# Optional: VAPID contact email. Falls back to RESEND_FROM_EMAIL → dev@skye-search.test.
# VAPID_SUBJECT=mailto:you@yourdomain.com
