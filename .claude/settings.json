{
  "permissions": {
    "allow": [
      "Write(.claude/.review-disposition-*)",
      "Edit(.claude/.review-disposition-*)",
      "Write(.claude/hooks/*)",
      "Edit(.claude/hooks/*)",
      "Write(.claude/settings.json)",
      "Edit(.claude/settings.json)",
      "Write(.claude/rules/*)",
      "Edit(.claude/rules/*)",
      "Write(scripts/*)",
      "Edit(scripts/*)",
      "Write(supabase/migrations/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/protect-review-results.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/commit-gate.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/prereq-gate.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/close-bead-gate.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/cross-review-enforce.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-npx.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-git-add-all.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-agent-review-auth.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-bead-delegation.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Evaluate this plan for completeness and quality. Check: (1) Does it have a Context section explaining WHY? (2) Does it have a Files Modified/Created table? (3) Does it have a Verification section? (4) Is there a simpler approach that achieves the same goal? (5) Are existing utilities/patterns being duplicated instead of reused? (6) What assumptions could be wrong? Respond with {\"ok\": false, \"reason\": \"specific improvements needed\"} if the plan is missing required sections or has obvious optimization opportunities. Respond {\"ok\": true} if the plan is solid. Plan context: $ARGUMENTS",
            "model": "haiku",
            "statusMessage": "Evaluating plan quality..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/command-logger.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/track-bead-claim.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-verify-stamp.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-agent-browser-stamp.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-golden-set-stamp.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/cross-review-gate.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-close-learn.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-evaluator-execute-nudge.sh"
          },
          {
            "type": "prompt",
            "if": "Write|Edit",
            "prompt": "Check if this file edit adds NEW imports from libraries that may have stale training data: @supabase/, @anthropic-ai/, resend, exa-js, next/, zod. Look at the actual content: $ARGUMENTS. If new library imports are added (not just editing existing code that already uses them), respond {\"ok\": false, \"reason\": \"Fetch Context7 docs for [specific library] before committing \u2014 training data may be stale\"}. If no new library imports, respond {\"ok\": true}.",
            "model": "haiku",
            "statusMessage": "Checking library imports..."
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-cross-review-capture.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-self-review-capture.sh"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-skill-stamp.sh"
          },
          {
            "type": "prompt",
            "if": "Skill(*impeccable*)",
            "prompt": "The /impeccable skill was just invoked. Verify the output in $ARGUMENTS is a REAL audit, not a rubber stamp.\n\nReal audit evidence (need at least 2 of these):\n  (1) Specific .tsx file paths with line numbers\n  (2) Concrete findings against .impeccable.md principles (tone, typography, color, layout, interaction)\n  (3) Actual fixes applied (Edit tool calls visible in output) OR justified no-op decisions\n\nRubber-stamp signals:\n  - Output is just \"Design context loaded. Stamped.\" or similar\n  - No file paths mentioned\n  - No specific critique, just generic praise\n  - Claims audit was done but no Read/Edit tool calls visible\n\nIf rubber-stamped, respond with:\n  {\"ok\": false, \"reason\": \"ADVISORY: /impeccable appears rubber-stamped \u2014 no file reads or concrete findings visible in output. If this is a UI bead, ask me to actually run the audit on the .tsx file against .impeccable.md and apply fixes before committing. This does NOT block the commit; it is a heads-up for you to decide.\"}\n\nIf real audit evidence exists, respond {\"ok\": true}.",
            "model": "haiku",
            "statusMessage": "Checking /impeccable audit quality (advisory only)..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-cleanup.sh"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/compact-reinject.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/inject-review-context.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-end-check.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-end-auto-wrap.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/retro-mandate.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/user-correction-detector.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/decide-dont-punt-detector.sh"
          }
        ]
      }
    ]
  }
}